<Window x:Class="PrjVabavaraValijaAken.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PrjVabavaraValijaAken"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Vali sobivad kriteeriumid"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="10"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="stkKriteeriumid" Margin="10"/>
        </ScrollViewer>
        <Button x:Name="btnLeiaTarkvara" Content="Leia sobiv tarkvara" HorizontalAlignment="Center" Margin="0,338,0,0" Grid.Row="1" VerticalAlignment="Top" Height="31" Width="134" Click="btnLeiaTarkvara_Click"/>

    </Grid>
</Window>
